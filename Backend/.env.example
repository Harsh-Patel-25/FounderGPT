# FounderGPT Backend Environment Variables

# Server
PORT=4999
NODE_ENV=development

# AI API Keys (At least one required for analysis)
GEMINI_API_KEY=your-gemini-api-key-here
NVIDIA_API_KEY=your-nvidia-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Preferred AI Service (nvidia, openai, gemini)
PREFERRED_AI_SERVICE=nvidia

# Local Fallback (set to 'true' to use mock data for testing UI without API calls)
ALLOW_LOCAL_AI_FALLBACK=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173
